{
  "info": {
    "name": "Ecommerce Backend - Sreenithi",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Sreenithi\",\n  \"email\": \"sree@gmail.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9999999999\",\n  \"address\": \"Chennai\"\n}" },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"sree@gmail.com\",\n  \"password\": \"password123\"\n}" },
            "url": "{{base_url}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Category",
      "item": [
        {
          "name": "Add Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic items\"\n}" },
            "url": "{{base_url}}/api/categories"
          }
        },
        { "name": "Get All Categories", "request": { "method": "GET", "url": "{{base_url}}/api/categories" } },
        { "name": "Get Category by ID", "request": { "method": "GET", "url": "{{base_url}}/api/categories/1" } },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics & Gadgets\",\n  \"description\": \"Updated description\"\n}" },
            "url": "{{base_url}}/api/categories/1"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/categories/1"
          }
        }
      ]
    },
    {
      "name": "3. Product",
      "item": [
        {
          "name": "Add Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"iPhone 15\",\n  \"description\": \"Latest Apple smartphone\",\n  \"price\": 79999.00,\n  \"stock\": 50,\n  \"brand\": \"Apple\",\n  \"lowStockThreshold\": 10\n}" },
            "url": "{{base_url}}/api/products?categoryId=1"
          }
        },
        { "name": "Get All Products", "request": { "method": "GET", "url": "{{base_url}}/api/products" } },
        { "name": "Get Product by ID", "request": { "method": "GET", "url": "{{base_url}}/api/products/1" } },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"iPhone 15 Pro\",\n  \"price\": 99999.00,\n  \"stock\": 30,\n  \"brand\": \"Apple\"\n}" },
            "url": "{{base_url}}/api/products/1?categoryId=1"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/products/1"
          }
        },
        { "name": "Search Product", "request": { "method": "GET", "url": "{{base_url}}/api/products/search?keyword=iphone" } },
        { "name": "Filter by Category", "request": { "method": "GET", "url": "{{base_url}}/api/products/category/1" } },
        { "name": "Filter by Price Range", "request": { "method": "GET", "url": "{{base_url}}/api/products/filter/price?min=1000&max=100000" } },
        { "name": "Filter by Brand", "request": { "method": "GET", "url": "{{base_url}}/api/products/filter/brand?brand=Apple" } },
        {
          "name": "Low Stock Alert",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/products/low-stock"
          }
        }
      ]
    },
    {
      "name": "4. Review",
      "item": [
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent product, super fast delivery!\"\n}" },
            "url": "{{base_url}}/api/reviews/product/1"
          }
        },
        { "name": "Get Reviews for Product", "request": { "method": "GET", "url": "{{base_url}}/api/reviews/product/1" } }
      ]
    },
    {
      "name": "5. Cart",
      "item": [
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}" },
            "url": "{{base_url}}/api/cart/add"
          }
        },
        {
          "name": "Update Cart",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": 1,\n  \"quantity\": 5\n}" },
            "url": "{{base_url}}/api/cart/update"
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/cart"
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/cart/remove/1"
          }
        }
      ]
    },
    {
      "name": "6. Order",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"shippingAddress\": \"12 Anna Nagar, Chennai, TN\",\n  \"paymentMethod\": \"COD\"\n}" },
            "url": "{{base_url}}/api/orders/place"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Changed my mind\"\n}" },
            "url": "{{base_url}}/api/orders/cancel/1"
          }
        },
        {
          "name": "Order History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/orders/history"
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/orders/all"
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/orders/1/status?status=SHIPPED"
          }
        }
      ]
    }
  ]
}
